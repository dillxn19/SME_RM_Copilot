# watsonx Orchestrate Environment Configuration
# Copy this file to .env and fill in your actual values

# Demo Mode (mock = synthetic data only, live = connect to real Orchestrate)
DEMO_MODE=mock

# watsonx Orchestrate Connection (for deployment)
# SaaS Example:
WXO_HOST_URL=https://us-south.watson-orchestrate.cloud.ibm.com
WXO_API_KEY=
WXO_ORCHESTRATION_ID=
WXO_CRN=

# Local Developer Edition Example:
# WXO_HOST_URL=http://localhost:8080
# WXO_API_KEY=local-dev-key

# Default Model for All Agents
WXO_DEFAULT_MODEL=groq/openai/gpt-oss-120b

# Demo Configuration
DEMO_TITLE="SME Relationship Manager Copilot - Built with IBM watsonx Orchestrate"
DEMO_CLIENT_CODE=BANK-001
DEMO_INDUSTRY=Financial Services - Commercial Banking

# Synthetic Data Configuration
FAKER_SEED=42
NUM_CUSTOMERS=10
HISTORY_DAYS=90

# Optional: watsonx.governance Integration
WATSONX_GOVERNANCE_URL=
WATSONX_GOVERNANCE_API_KEY=

# Optional: If building Hybrid UI shell
VITE_WXO_HOST_URL=https://us-south.watson-orchestrate.cloud.ibm.com
VITE_WXO_ORCHESTRATION_ID=
VITE_WXO_CRN=
VITE_WXO_AGENT_ID=

# Security Notice
# NEVER commit real credentials to version control
# All customer data in this demo is 100% synthetic